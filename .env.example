# ─── App URL (usado nas redirects Stripe) ──────────────────────────────────────
# Em dev: http://localhost:3000  |  Em produção: https://tua-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Firebase CLIENT (browser, público) ───────────────────────────────────────
# Em Firebase Console → Project Settings → "Os teus apps" → Web app → Config
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ─── Cloudinary (alojamento de imagens — fotos de equipamentos e avatares) ─────
# cloudinary.com → Dashboard → "Cloud name"
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
# cloudinary.com → Settings → Upload → Upload presets → criar preset "Unsigned" → copiar nome
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# ─── Firebase ADMIN (servidor, SECRETO) ────────────────────────────────────────
# Firebase Console → Project Settings → Service Accounts → "Generate new private key"
# Copia os 3 valores do JSON descarregado:
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# A private key tem de ficar entre aspas e com os \n literais (não quebras reais):
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── Stripe (pagamentos) ───────────────────────────────────────────────────────
# stripe.com → Dashboard → Developers → API keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
# stripe.com → Developers → Webhooks → "Adicionar endpoint" → Escuta: checkout.session.completed,
#   customer.subscription.updated, customer.subscription.deleted → copiar "Signing secret"
STRIPE_WEBHOOK_SECRET=whsec_...
# stripe.com → Products → criar produto "Pro 29€/mês" e "Business 79€/mês" → copiar Price ID
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_BUSINESS=price_...
